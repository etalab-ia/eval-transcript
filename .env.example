# Local API configuration. Copy to `.env` and fill in secrets locally.

# oMLX local OpenAI-compatible API
OMLX_BASE_URL=http://localhost:8000/v1
OMLX_API_KEY=

# Albert API
ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1
ALBERT_API_KEY=

# OpenRouter (juge LLM tiers, pour éviter le biais Mistral-juge-Mistral)
# Catalogue des modèles : https://openrouter.ai/models
OPENROUTER_API_KEY=
# Facultatif : surcharge de l'URL de base (défaut https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=
# Facultatif : attribution dans les classements OpenRouter
OPENROUTER_APP_TITLE=eval-transcript
OPENROUTER_APP_URL=

# Scaleway Generative APIs (only the secret key and project ID are required)
SCW_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=

# ElevenLabs Speech to Text
ELEVENLABS_API_KEY=
# Optional regional or custom base URL
ELEVENLABS_BASE_URL=
